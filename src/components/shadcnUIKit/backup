import { useEffect, useState } from "react";
import { useNavigate, useLocation } from "react-router-dom";
import useModalStack from "@/hooks/useModalStack";
import { useRecoilValue, useRecoilState, useResetRecoilState } from "recoil";
import { newScheduleFormValue, updateScheduleFormValue, isScheduleFormModifiedSelector } from "@/store";

import ScheduleService from "@/services/scheduleService";

import FixedTrigger from "../mocules/FixedTrigger";
import Header from "../organisms/Header"
import SlideTransition from "../organisms/SlideTransition";
import ScheduleForm from "../organisms/ScheduleForm"
import ScheduleCardField from "../mocules/ScheduleCardField";
import ScheduleCard from "../atoms/ScheduleCard";

import { produce } from "immer"
import formatDate from "@/utils/formatDate";

import IconCirclePlus from "../../assets/images/icon-circle-plus.svg?react";

import { ScheduleFormValueType } from "@/store";

const AddSchedulePage = () => {

  const location = useLocation();
  const {
    id: scheduleId,
    data: scheduleData,
    isAddSchedule,
    isAddingScheduleDetail: isAddScheduleDetail,
    inProgressFormNumber,
    scheduleLocation,
    isScheduleFormModified: isFormModified
  } = location.state || {};
  const isAddingLocation = inProgressFormNumber === 0 || inProgressFormNumber

  // const isAddingScheduleDetail

  const resetScheduleFormState = useResetRecoilState(newScheduleFormValue);
  const isScheduleFormModified = useRecoilValue(isScheduleFormModifiedSelector);
  const [newScheduleFormValueState, setNewScheduleFormValueState] = useRecoilState(newScheduleFormValue);
  const [updateScheduleFormValueState, setUpdateScheduleFormValueState] = useRecoilState(updateScheduleFormValue);

  const [scheduleFormValueSnapshot, setScheduleFormValueSnapshot] = useState(scheduleData ? scheduleData as ScheduleFormValueType : newScheduleFormValueState);
  const [preUploadFormData, setPreUploadFormData] = useState(scheduleFormValueSnapshot)
  const [isEditingScheduleDetail, setIsEditingScheduleDetail] = useState<boolean>(false);
  const [isAddingScheduleDetail, setIsAddingScheduleDetail] = useState<boolean>(false);
  const [addScheduleDate, setAddScheduleDate] = useState<string>("");
  const [editScheduleIndex, setEditScheduleIndex] = useState<number>(inProgressFormNumber);
  const [isFetching, setIsFetching] = useState<boolean>(true);
  const [progress, setProgress] = useState<number>(isAddingLocation ? 1 : 0);
  const [direction, setDirection] = useState<"next" | "prev">("next");

  const { openModal, closeModal, closeModalDirect } = useModalStack()
  const navigate = useNavigate();

  const { ManageSchedulesHeader } = Header();

  const scheduleState = isAddSchedule ? newScheduleFormValueState : scheduleFormValueSnapshot
  const setScheduleState = isAddSchedule ? setNewScheduleFormValueState : setScheduleFormValueSnapshot

  const { startTime, endTime, scheduleName, scheduleDetails } = scheduleState;

  const { CreateSchedule, UpdateSchedule, DeleteSchedule } = ScheduleService()
  const { mutate: createScheduleMutate, isPending: createScheduleIsPending } = CreateSchedule(
    () => {
      onFetchComplete("일정이 추가되었습니다.")
      resetScheduleFormState()
    }, () => {
      onFetchComplete("일정 추가를 실패했습니다.")
      resetScheduleFormState()
    })

  const { mutate: updateScheduleMutate, isPending: UpdateScheduleIsPending } = UpdateSchedule(
    { id: scheduleId, data: scheduleState },
    () => {
      onFetchComplete("일정이 수정되었습니다.")
    }, () => {
      onFetchComplete("일정 수정을 실패했습니다.")
    })

  const { mutate: DeleteScheduleMutate, isPending: DeleteScheduleIsPending } = DeleteSchedule(scheduleId,
    () => {
      onFetchComplete("일정이 삭제되었습니다.")
    },
    () => {
      onFetchComplete("일정 삭제를 실패했습니다.")
    }
  )

  const onFetchComplete = (message: string) => {
    setIsFetching(true)
    closeModal();
    setTimeout(() => {
      openModal("Toast", { isFail: message.includes("실패"), message });
    }, 500)
    navigate("/schedule", {
      state: { direction: "prev" },
    })
  }

  if (createScheduleIsPending && isFetching) {
    openModal("Loading", { isLoader: false, message: "일정 추가 중..." });
    setIsFetching(false)
  }

  if (UpdateScheduleIsPending && isFetching) {
    openModal("Loading", { isLoader: false, message: "일정 수정 중..." });
    setIsFetching(false)
  }

  if (DeleteScheduleIsPending && isFetching) {
    openModal("Loading", { isLoader: false, message: "일정 삭제 중..." });
    setIsFetching(false)
  }

  const handlePreviousProgress = () => {
    if (progress === 0 && isScheduleFormModified && isAddSchedule) {
      openModal("Alert", "임시저장을 하시겠습니까?", ["삭제", "확인"],
        [
          () => {
            closeModal()
            navigate("/schedule", {
              state: { direction: "prev" },
            })
            resetScheduleFormState()
          },
          () => {
            closeModal()
            navigate("/schedule", {
              state: { direction: "prev" },
            })
          }
        ])
    } else if (progress === 1) {
      setIsEditingScheduleDetail(false)
      setIsAddingScheduleDetail(false)
      setProgress(0)
      setDirection("prev")
      isAddingScheduleDetail ? deleteScheduleDetail() : cancelEditScheduleDetail()
    } else {
      navigate("/schedule/detail", {
        state: {
          direction: "prev",
          id: scheduleId,
          data: scheduleData,
        },
      })
    }
  }

  const handleNextProgress = () => {
    if (progress === 0 && isAddSchedule) {
      openModal("Alert", "일정을 추가하시겠습니까?", ["취소", "확인"],
        [null,
          () => {
            closeModalDirect()
            createScheduleMutate()
          }
        ])
    } else if (progress === 0 && !isAddSchedule) {
      openModal("Alert", "일정을 수정하시겠습니까?", ["취소", "확인"],
        [null,
          () => {
            closeModalDirect()
            updateScheduleMutate()
          }
        ])
    } else {
      setIsEditingScheduleDetail(false)
      setIsAddingScheduleDetail(false)
      setProgress(0)
      setDirection("prev")
      addScheduleDetail()
    }
  }

  const addScheduleDetailDefault = (time: string) => {
    setIsAddingScheduleDetail(true)
    setAddScheduleDate(time)
    setProgress(1)
    setDirection("next")
    const newScheduleFormValueState = produce(preUploadFormData, (draft) => {
      draft.scheduleDetails.push({
        selectedDay: time,
        startTime: "00:00",
        endTime: "00:00",
        scheduleName: "",
        scheduleLocation: {
          placeName: "",
          placeAddress: "",
          placeId: "",
          lat: 0,
          lng: 0,
        },
        memoContent: ""
      })
    })
    setPreUploadFormData(newScheduleFormValueState)
  }

  const addScheduleDetail = () => {
    if (isEditingScheduleDetail) {
      const newScheduleFormValueState = produce(scheduleState, (draft) => {
        draft.scheduleDetails[editScheduleIndex] = preUploadFormData.scheduleDetails[editScheduleIndex]
        draft.scheduleDetails.sort((a, b) => new Date(`${a.selectedDay} ${a.startTime}`).getTime() - new Date(`${b.selectedDay} ${b.startTime}`).getTime());
      })
      setScheduleState(newScheduleFormValueState);
    }
    else {
      const newScheduleFormValueState = produce(scheduleState, (draft) => {
        draft.scheduleDetails.push(preUploadFormData.scheduleDetails[preUploadFormData.scheduleDetails.length - 1]);
        draft.scheduleDetails.sort((a, b) => new Date(`${a.selectedDay} ${a.startTime}`).getTime() - new Date(`${b.selectedDay} ${b.startTime}`).getTime());
      });
      setScheduleState(newScheduleFormValueState);
    }
  }

  const cancelEditScheduleDetail = () => {
    if (isEditingScheduleDetail) {
      const newScheduleFormValueState = produce(preUploadFormData, (draft) => {
        draft.scheduleDetails[editScheduleIndex] = scheduleState.scheduleDetails[editScheduleIndex]
      })
      setPreUploadFormData(newScheduleFormValueState);
    }
  }

  const deleteScheduleDetail = () => {
    setIsEditingScheduleDetail(false)
    setProgress(0)
    setDirection("prev")
    if (isEditingScheduleDetail) {
      const newScheduleFormValueState = produce(scheduleState, (draft) => {
        draft.scheduleDetails.splice(editScheduleIndex, 1);
      })
      setPreUploadFormData(newScheduleFormValueState);
      setScheduleState(newScheduleFormValueState);
    }
  }

  const getDatesBetween = (startDate: string, endDate: string) => {
    const dates = [];
    const startDateArray = startDate.split("-");
    const currentDate = new Date(Date.UTC(+startDateArray[0], +startDateArray[1] - 1, +startDateArray[2]));
    const endDateArray = endDate.split("-");
    const end = new Date(Date.UTC(+endDateArray[0], +endDateArray[1] - 1, +endDateArray[2]));

    while (currentDate <= end) {
      dates.push(new Date(currentDate));
      currentDate.setUTCDate(currentDate.getUTCDate() + 1);
    }

    return dates.map(date => date.toISOString().split("T")[0]);
  };

  useEffect(() => {
    if (!isAddSchedule && JSON.stringify(scheduleData) !== JSON.stringify(scheduleState)) {
      const { ...newState } = location.state;
      navigate("/schedule/update", { state: { ...newState, isScheduleFormModified: true }, replace: true });
    }
  }, [scheduleState])

  useEffect(() => {
    if (isAddingLocation) {
      const newScheduleFormValueState = produce(scheduleData as ScheduleFormValueType, (draft) => {
        draft.scheduleDetails[inProgressFormNumber].scheduleLocation = scheduleLocation
      })
      setPreUploadFormData(newScheduleFormValueState)
      setIsEditingScheduleDetail(true)
      isAddScheduleDetail && setIsAddingScheduleDetail(true)
      setEditScheduleIndex(inProgressFormNumber)
    }

    if (isFormModified) {
      navigate("/schedule", {
        state: { direction: "prev" },
      })
    }
  }, [])

  return (
    <>
      <FixedTrigger className="z-20 top-0" height={40} enableAnimation={false}>
        <ManageSchedulesHeader
          handleFunc={[handlePreviousProgress, handleNextProgress]}
          isEdit={isAddSchedule ? (isAddingScheduleDetail ? "추가" : isEditingScheduleDetail ? "수정" : "추가") : (isAddingScheduleDetail ? "추가" : isEditingScheduleDetail ? "수정" : "수정")}
          title={
            progress === 0
              ? isAddSchedule ? "일정 추가" : "일정 수정"
              : `${formatDate(addScheduleDate ? addScheduleDate : preUploadFormData.scheduleDetails[editScheduleIndex].selectedDay, 5).slice(1)} 일정 ${isAddSchedule ? (isAddingScheduleDetail ? "추가" : isEditingScheduleDetail ? "수정" : "추가") : (isAddingScheduleDetail ? "추가" : isEditingScheduleDetail ? "수정" : "수정")}`
          }
          isRequired={
            progress === 0 && (scheduleName !== "" && startTime !== "" && endTime !== "") ||
            progress === 1 && preUploadFormData.scheduleDetails[preUploadFormData.scheduleDetails.length - 1].scheduleName !== ""
          }
        />
      </FixedTrigger>

      <SlideTransition className="mt-[30px] px-[30px]" progress={progress} direction={direction} >
        {progress === 1 &&
          <>
            <ScheduleForm
              isAddSchedule={isAddSchedule}
              isAddingScheduleDetail={isAddingScheduleDetail}
              scheduleId={scheduleId}
              formData={preUploadFormData}
              setFormData={setPreUploadFormData}
              isPrimarySchedule={false}
              detailedScheduleId={isEditingScheduleDetail ? editScheduleIndex : preUploadFormData.scheduleDetails.length - 1}
            />

            {isEditingScheduleDetail &&
              <button className="mt-[30px] w-full h-[60px] rounded-[10px] flex-center gap-[10px] bg-input" type="button"
                onClick={deleteScheduleDetail}>
                <p className="text-md text-red">일정 삭제</p>
              </button>
            }
          </>
        }

        {progress === 0 &&
          <>
            <ScheduleForm
              formData={scheduleState}
              setFormData={setScheduleState}
            />

            <div className={`mt-[30px] pb-[20px] flex flex-col gap-[15px] transition duration-300 ${startTime && endTime && new Date(startTime) <= new Date(endTime) ? "opacity-100" : "opacity-0"}`}>
              <h2 className="text-lg text-white">세부 일정</h2>

              {scheduleDetails.map((scheduleDetail, index) =>
                <ScheduleCardField key={index} label={formatDate(new Date(scheduleDetail.selectedDay), 5)} >
                  <ScheduleCard
                    data={scheduleDetail}
                    handleFunc={() => {
                      setIsEditingScheduleDetail(true)
                      setProgress(1)
                      setDirection("next")
                      setEditScheduleIndex(index)
                      setAddScheduleDate(scheduleDetail.selectedDay)
                    }}
                    isSlideEnabled={false}
                    onAddress={true} />
                </ScheduleCardField>
              )}

              {getDatesBetween(startTime, endTime).map((time, index) => (
                <ScheduleCardField key={index} label={formatDate(time, 5)} >
                  <button className="w-full h-[70px] rounded-[10px] flex-center gap-[10px] bg-white" type="button"
                    onClick={() => { addScheduleDetailDefault(time) }}>
                    <IconCirclePlus width={20} height={20} fill={"var(--black)"} />
                    <p className="text-md text-black">일정 추가</p>
                  </button>
                </ScheduleCardField>
              ))}

              {!isAddSchedule &&
                <button className="mt-[30px] w-full h-[60px] rounded-[10px] flex-center gap-[10px] bg-input" type="button"
                  onClick={() => {
                    openModal("Alert", "일정을 삭제하시겠습니까?", ["취소", "확인"],
                      [null,
                        () => {
                          closeModalDirect()
                          DeleteScheduleMutate()
                        }
                      ])
                  }}>
                  <p className="text-md text-red">일정 삭제</p>
                </button>
              }
            </div>
          </>
        }
      </SlideTransition >
    </>
  )
}

export default AddSchedulePage

















