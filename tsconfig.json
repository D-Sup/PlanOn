{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "node", // "bundler" 는 표준 옵션이 아니므로 "node"로 변경합니다.
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "jsx": "react-jsx",
    "strict": false, // 엄격한 타입 체크를 비활성화합니다.
    "noImplicitAny": true, // 모든 타입을 any로 처리하여 명시적이지 않은 타입 에러를 방지합니다.
    "noImplicitReturns": false, // 함수에서 모든 경로가 값을 반환하지 않아도 됩니다.
    "noImplicitThis": false, // this 표현의 암시적 'any' 타입을 허용합니다.
    "noEmitOnError": false, // 에러가 있어도 파일을 생성합니다.
    "allowSyntheticDefaultImports": true,
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
